# Backend secrets contract — copy to .env (git-ignored) and fill from your password manager.
# Local dev uses docker-compose defaults; cloud values are needed at deploy.

# runtime
ENVIRONMENT=local                                              # local|dev|test enable the X-Dev-User-Id auth fallback

# db / cache
DATABASE_URL=postgresql+asyncpg://glasshouse:glasshouse@localhost:5432/glasshouse        # owner role
APP_DATABASE_URL=postgresql+asyncpg://glasshouse_app:glasshouse_app@localhost:5432/glasshouse  # RLS app role
DATABASE_URL_DIRECT=                                            # Neon direct (Alembic), prod
REDIS_URL=redis://localhost:6379                                # local compose default

# crypto (MVP master key; upgrade to KMS later)
MASTER_KEY=                                                     # openssl rand -hex 32

# auth (Clerk — server side; ONE shared instance, the FE uses the matching publishable key)
CLERK_ISSUER=                                                  # Frontend API URL, e.g. https://<slug>.clerk.accounts.dev
CLERK_JWKS_URL=                                                # {CLERK_ISSUER}/.well-known/jwks.json
CLERK_AUDIENCE=                                                # optional — leave blank (default Clerk tokens carry no aud)
CLERK_SECRET_KEY=                                              # sk_test_… / sk_live_…
CLERK_WEBHOOK_SECRET=                                          # whsec_… from the Dashboard webhook endpoint (Svix)

# cors (browser origins allowed to call the API; comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000

# object storage (Cloudflare R2, S3-compatible)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=glasshouse-media

# llm gateway (app holds ONLY the proxy virtual key; provider keys live in the proxy)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_VIRTUAL_KEY=

# observability (optional)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
